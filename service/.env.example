# ── Standalone Spinner service — environment ──────────────────────────────
# Copy to `.env` and fill in. NEVER commit the real .env (gitignored). All
# secrets are read at runtime from the environment, never hardcoded.

# --- Models / providers ---
OPENROUTER_API_KEY=                 # free-tier translation (OpenRouter :free models)
INWORLD_API_KEY=                    # Inworld AIMS key (everything scope) — TTS + voices + router
INWORLD_REALTIME_API_KEY=           # Inworld SPINNER key (realtime-only scope) — the duplex WS
GEMINI_API_KEY=                     # Google Gemini API key — engine=gemini (gemini-3.5-live-translate-preview)
# GEMINI_LIVE_MODEL=gemini-3.5-live-translate-preview
# INWORLD_ROUTER_URL=https://api.inworld.ai/v1/chat/completions
# INWORLD_TTS_BASE=https://api.inworld.ai
# INWORLD_TTS_MODEL=inworld-tts-2

# --- Voice ---
SPINNER_DEFAULT_VOICE=default-4zhua1rhxjfl50z1dnkcba__foai-charlotte-v1

# --- Identity (shared with the consuming app, e.g. Coastal) ---
SPINNER_AUTH_SECRET=                # == Coastal's COASTAL_AUTH_SECRET (verifies the signed coastal_uid cookie)

# --- Tier / billing source ---
SPINNER_TIER_SOURCE=local           # local | callback
# SPINNER_TIER_CALLBACK_URL=        # if callback: the consuming app's verify URL (?uid=...) -> {paid:bool}

# --- Service boundary auth ---
SPINNER_SERVICE_TOKEN=              # bridge holds this; HTTP API requires X-Service-Token == this
SPINNER_REQUIRE_SERVICE_TOKEN=true  # true=BRIDGE mode (gate HTTP); false=DIRECT mode (own domain, cookie auth)

# --- Realtime cost guard ---
SPINNER_RT_IDLE_SECONDS=120         # close the WS after N seconds of no audio (the real cost guard)
SPINNER_RT_MAX_SECONDS=3600         # hard backstop for a stuck-but-active session

# --- Database (Neon Postgres) ---
# App/runtime: set DATABASE_URL in the environment (deploy secret / gitignored .env). NEVER commit the real value.
DATABASE_URL=                       # postgresql://USER:PASSWORD@HOST/neondb?sslmode=require&channel_binding=require  (use the -pooler host)
# Interactive human access WITHOUT a password — opens a browser OAuth flow, no string to paste/store:
#   psql -h pg.neon.tech

# --- Freemium meter ---
SPINNER_FREE_TOKEN_CAP=300000       # free monthly token cap → upgrade trigger

# --- Billing (Stripe) — money path runs ONLY when these are set ---
STRIPE_SECRET_KEY=                  # sk_live_... (or sk_test_...) — never commit
STRIPE_WEBHOOK_SECRET=              # whsec_... — verifies /api/v1/billing/webhook
SPINNER_PUBLIC_URL=                 # https://spinner.aims.works — success/cancel redirect base
SPINNER_DRIP_REVEAL_REMAINING=0.20  # slow-drip: reveal plans when BMC bucket hits this fraction remaining
# Price IDs from `python stripe_setup.py` (one-time prices per SKU):
# STRIPE_PRICE_BMC=price_...
# STRIPE_PRICE_DRIP_3=  STRIPE_PRICE_DRIP_6=  STRIPE_PRICE_DRIP_9=
# STRIPE_PRICE_FLOW_3=  STRIPE_PRICE_FLOW_6=  STRIPE_PRICE_FLOW_9=
# STRIPE_PRICE_CURRENT_3=  STRIPE_PRICE_CURRENT_6=  STRIPE_PRICE_CURRENT_9=

# --- CORS (DIRECT mode) ---
# SPINNER_CORS_ORIGINS=https://spinner.aimanagedsolutions.cloud

# --- Stores (SQLite; persisted via the spinner_data volume) ---
# SPINNER_IDENTITY_DB=/app/data/spinner_identity.db
